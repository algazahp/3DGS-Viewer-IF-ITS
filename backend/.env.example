# Salin file ini ke .env dan sesuaikan nilainya
# cp .env.example .env

# Port server Express
PORT=3000

# Path lokal ke folder berisi file .sog (untuk testing tanpa Cloudflare R2)
# Windows path: gunakan forward slash atau escape backslash
LOCAL_SPLAT_DIR=G:/TugasAkhir/ScriptConvert

# Origin frontend yang diizinkan CORS (pisahkan dengan koma untuk multiple)
# Development: http://127.0.0.1:5500 (Live Server VS Code)
# Production: https://<username>.github.io
FRONTEND_ORIGIN=http://127.0.0.1:5500
